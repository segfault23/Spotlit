{
  "name": "spotlit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && cp lambda.mjs build/lambda.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "prettier --check . && eslint .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,svelte}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.0.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1037.0",
    "@aws-sdk/client-dynamodb": "^3.1037.0",
    "@aws-sdk/lib-dynamodb": "^3.1037.0",
    "aws-jwt-verify": "^4.0.1",
    "serverless-http": "^3.2.0"
  }
}
