# Copy to .env and fill in values for local development.

# Bypass Cognito — set a fixed user identity (sub:email:name).
# The sub is used as the DynamoDB partition key, so keep it consistent.
DEV_USER=dev-local-001:dev@local:Dev User

# DynamoDB table name (from CDK output: SpotlitCdkStack.ContentTableName)
CONTENT_TABLE=

# AWS credentials — or set AWS_PROFILE in your shell instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
